{
  "manifest_version": 3,
  "name": "Copilot Dash",
  "description": "View Copilot CLI run results for matching pages in a side panel",
  "version": "1.0.0",
  "permissions": ["sidePanel", "activeTab", "tabs", "webNavigation"],
  "host_permissions": ["http://localhost:3456/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-inactive-16.png",
    "48": "icons/icon-inactive-48.png",
    "128": "icons/icon-inactive-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-inactive-16.png",
      "48": "icons/icon-inactive-48.png"
    },
    "default_title": "Copilot Dash"
  }
}
